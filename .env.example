# Deployer key — NEVER commit the real .env (NFR-6)
PRIVATE_KEY=

# GenLayer network — StudioNet (hosted, gasless studio network)
RPC_URL=https://studio.genlayer.com/api
CHAIN_ID=61999

# Frontend (app/.env.local) — leave addresses empty to run the mock adapter
VITE_MOCK=1
VITE_RPC_URL=https://studio.genlayer.com/api
VITE_ADDR_REGISTRY=
VITE_ADDR_ARBITER=
VITE_ADDR_VAULT=
VITE_ADDR_LOG=
VITE_ADDR_APPEALS=

# Privy wallet connect — app id from https://dashboard.privy.io
# Wallet connect stays inert (button shows a hint) until this is set.
VITE_PRIVY_APP_ID=
